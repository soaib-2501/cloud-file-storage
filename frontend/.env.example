# Copy this to .env.local and fill in values from SAM deploy output

# API Gateway URL (from: sam deploy output → ApiUrl)
NEXT_PUBLIC_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# AWS Cognito (from: sam deploy output → UserPoolId, UserPoolClientId)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CloudFront CDN (from: sam deploy output → CloudFrontUrl)
NEXT_PUBLIC_CLOUDFRONT_URL=https://xxxxxxxxxxxxxxxxxx.cloudfront.net
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=xxxxxxxxxxxxxxxxxx.cloudfront.net

# AWS Region
NEXT_PUBLIC_AWS_REGION=us-east-1
